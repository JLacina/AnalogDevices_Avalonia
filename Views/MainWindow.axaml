<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:HardwareDeviceConfigManager.ViewModels"
        x:Class="HardwareDeviceConfigManager.Views.MainWindow"
        Title="Hardware Device Config Manager"
        Width="1100" Height="680"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E2E">

  <DockPanel LastChildFill="True">

    <!-- ── Title Bar ── -->
    <Border DockPanel.Dock="Top" Background="#2A2A3E" Padding="16,10">
      <StackPanel Orientation="Horizontal" Spacing="12">
        <TextBlock Text="⚙" FontSize="22" Foreground="#7C9EFF" VerticalAlignment="Center"/>
        <TextBlock Text="Hardware Device Config Manager" FontSize="18" FontWeight="Bold"
                   Foreground="White" VerticalAlignment="Center"/>
        <TextBlock Text="| Interview Demo — MVVM + HAL" FontSize="12"
                   Foreground="#888" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- ── Status Bar ── -->
    <Border DockPanel.Dock="Bottom" Background="#12121E" Padding="12,6">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock Grid.Column="0" Text="{Binding StatusMessage}" Foreground="#AAAACC"
                   FontSize="12" VerticalAlignment="Center"/>
        <ProgressBar Grid.Column="1" IsIndeterminate="True" Width="120" Height="6"
                     IsVisible="{Binding IsBusy}" Foreground="#7C9EFF"/>
      </Grid>
    </Border>

    <!-- ── Main Content ── -->
    <Grid Margin="12">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="1.4*"/>
        <ColumnDefinition Width="12"/>
        <ColumnDefinition Width="1*"/>
      </Grid.ColumnDefinitions>

      <!-- ── Left: Device List ── -->
      <Border Grid.Column="0" Background="#2A2A3E" CornerRadius="8" Padding="0">
        <DockPanel>
          <Border DockPanel.Dock="Top" Background="#313150" CornerRadius="8,8,0,0" Padding="12,8">
            <TextBlock Text="📋  Device List" FontWeight="SemiBold" Foreground="#7C9EFF" FontSize="13"/>
          </Border>
          <DataGrid DockPanel.Dock="Top"
                    ItemsSource="{Binding Devices}"
                    SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    CanUserSortColumns="True"
                    GridLinesVisibility="Horizontal"
                    Background="Transparent"
                    RowBackground="#2A2A3E"
                    BorderThickness="0"
                    Foreground="#DDDDEE"
                    FontSize="12">
            <DataGrid.Columns>
              <DataGridTextColumn Header="Id"           Binding="{Binding Id}"             Width="45"/>
              <DataGridTextColumn Header="Device Name"  Binding="{Binding DeviceName}"      Width="160"/>
              <DataGridTextColumn Header="Type"         Binding="{Binding DeviceType}"      Width="110"/>
              <DataGridTextColumn Header="Connection"   Binding="{Binding ConnectionType}"  Width="95"/>
              <DataGridTextColumn Header="Firmware"     Binding="{Binding FirmwareVersion}" Width="80"/>
              <DataGridTextColumn Header="Status"       Binding="{Binding Status}"          Width="100"/>
            </DataGrid.Columns>
          </DataGrid>
        </DockPanel>
      </Border>

      <!-- ── Splitter ── -->
      <GridSplitter Grid.Column="1" Width="4" Background="#12121E" VerticalAlignment="Stretch"/>

      <!-- ── Right: Edit Form ── -->
      <Border Grid.Column="2" Background="#2A2A3E" CornerRadius="8">
        <DockPanel>
          <!-- Form Header -->
          <Border DockPanel.Dock="Top" Background="#313150" CornerRadius="8,8,0,0" Padding="12,8">
            <TextBlock Text="🖊  Device Details" FontWeight="SemiBold" Foreground="#7C9EFF" FontSize="13"/>
          </Border>

          <!-- Button Bar -->
          <Border DockPanel.Dock="Bottom" Background="#1E1E2E" CornerRadius="0,0,8,8" Padding="10,8">
            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Center">
              <Button Content="➕ Add"        Command="{Binding AddDeviceCommand}"         Margin="4,2" Padding="10,6" Background="#3A7BD5" Foreground="White" CornerRadius="4"/>
              <Button Content="✏ Update"      Command="{Binding UpdateDeviceCommand}"      Margin="4,2" Padding="10,6" Background="#2E7D32" Foreground="White" CornerRadius="4"/>
              <Button Content="🗑 Delete"     Command="{Binding DeleteDeviceCommand}"      Margin="4,2" Padding="10,6" Background="#C62828" Foreground="White" CornerRadius="4"/>
              <Button Content="✖ Clear"       Command="{Binding ClearFormCommand}"         Margin="4,2" Padding="10,6" Background="#555577" Foreground="White" CornerRadius="4"/>
              <Button Content="🔌 Connect"    Command="{Binding SimulateConnectCommand}"   Margin="4,2" Padding="10,6" Background="#00695C" Foreground="White" CornerRadius="4"/>
              <Button Content="⏏ Disconnect" Command="{Binding SimulateDisconnectCommand}" Margin="4,2" Padding="10,6" Background="#E65100" Foreground="White" CornerRadius="4"/>
            </WrapPanel>
          </Border>

          <!-- Form Fields -->
          <ScrollViewer Padding="16">
            <StackPanel Spacing="12">

              <TextBlock Text="Device Name *" Foreground="#AAAACC" FontSize="11"/>
              <TextBox Text="{Binding FormDeviceName, Mode=TwoWay}" Watermark="e.g. Oscilloscope A"/>

              <TextBlock Text="Device Type" Foreground="#AAAACC" FontSize="11"/>
              <TextBox Text="{Binding FormDeviceType, Mode=TwoWay}" Watermark="e.g. Oscilloscope, DAQ, Sensor"/>

              <TextBlock Text="Firmware Version *" Foreground="#AAAACC" FontSize="11"/>
              <TextBox Text="{Binding FormFirmwareVersion, Mode=TwoWay}" Watermark="e.g. 2.1.0"/>

              <TextBlock Text="Connection Type" Foreground="#AAAACC" FontSize="11"/>
              <ComboBox SelectedItem="{Binding FormConnectionType, Mode=TwoWay}"
                        ItemsSource="{Binding ConnectionTypes}"
                        HorizontalAlignment="Stretch"/>

              <TextBlock Text="Status" Foreground="#AAAACC" FontSize="11"/>
              <ComboBox SelectedItem="{Binding FormStatus, Mode=TwoWay}"
                        ItemsSource="{Binding StatusValues}"
                        HorizontalAlignment="Stretch"/>

              <TextBlock Text="Notes" Foreground="#AAAACC" FontSize="11"/>
              <TextBox Text="{Binding FormNotes, Mode=TwoWay}"
                       Watermark="Optional notes..."
                       AcceptsReturn="True"
                       Height="70"
                       TextWrapping="Wrap"/>

              <!-- Status badge for selected device -->
              <Border Background="#1A1A2E" CornerRadius="6" Padding="10,8" Margin="0,8,0,0">
                <StackPanel Spacing="4">
                  <TextBlock Text="Selected Device Status" Foreground="#666688" FontSize="10"/>
                  <TextBlock Text="{Binding FormStatus}" Foreground="#7C9EFF" FontSize="15" FontWeight="Bold"/>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>
        </DockPanel>
      </Border>
    </Grid>
  </DockPanel>
</Window>
